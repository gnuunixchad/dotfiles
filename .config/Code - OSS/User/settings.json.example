// vim:ft=json
// settings.json
// @author nate zhou
// @since 2023,2024,2025,2026

{
    "redhat.telemetry.enabled": false,
    // fix vscodevim not using the swapped ESC and CAPSLOCK on Linux
    "keyboard.dispatch": "keyCode",
    "editor.wordWrap": "on",
    "editor.fontFamily": "Source Code Pro",
    "editor.fontSize": 15,
    "window.zoomLevel": 1,
    "window.zoomPerWindow": false,
    "editor.cursorBlinking": "solid",
    "editor.scrollbar.verticalScrollbarSize": 1,
    "editor.scrollbar.horizontalScrollbarSize": 1,
    "editor.lineDecorationsWidth": 0,
    "editor.minimap.enabled": false,
    // break point
    "editor.glyphMargin": false,

    "extensions.autoCheckUpdates": false,
    "extensions.autoUpdate": false,

    // vim extension
    "vim.neovimConfigPath": "~/.config/nvim/init.lua",
    "vim.neovimPath": "/usr/bin/nvim",
    "vim.neovimUseConfigFile": true,
    "vim.useSystemClipboard": true,
    "vim.foldfix": true,

    "explorer.confirmDelete": false,
    "workbench.startupEditor": "newUntitledFile",
    "window.menuBarVisibility": "toggle",
    "editor.lineNumbers": "relative",
    "workbench.editor.showTabs": "none",
    "editor.renderWhitespace": "trailing",
    "window.titleBarStyle": "native",
    "window.customTitleBarVisibility": "never",
    "workbench.iconTheme": "vs-minimal",

    "workbench.colorCustomizations":{
        "editor.background": "#111111",
        "editorGutter.background": "#111111",
        "editorLineNumber.activeForeground": "#ffffff",
        "editorLineNumber.foreground": "#444444",
        "sideBar.background": "#111111",
        "activityBar.background": "#111111",
        "statusBar.background": "#427b58",
        "statusBar.foreground": "#eeeeee"
    },

    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "editor.autoClosingDelete": "never",
    "editor.autoClosingOvertype": "never",
    "editor.autoClosingBrackets": "never",
    "editor.autoClosingComments": "never",
    "editor.autoClosingQuotes": "never",
    "editor.autoSurround": "never",
    "editor.comments.insertSpace": false,
    "workbench.activityBar.location": "hidden",
    "update.showReleaseNotes": false,

    // anti-feature
    "chat.disableAIFeatures": true,
    "chat.extensionUnification.enabled": false,
    "telemetry.feedback.enabled": false,
    "telemetry.editStats.enabled": false,
    "telemetry.telemetryLevel": "off",
    "workbench.enableExperiments": false,
    "workbench.commandPalette.experimental.enableNaturalLanguageSearch": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "extensions.experimental.issueQuickAccess": false,
    "extensions.ignoreRecommendations": true
}
