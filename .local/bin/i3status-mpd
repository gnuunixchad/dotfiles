#!/usr/bin/env bash
# @author nate zhou
# @since 2025
# external script for i3status on swaybar

i3status | while :
# mpd
do
    read line
    printf -v my_song "%q" "$(mpc current -f "[%title%]" | cut -c1-40)"
    if [ -n "$(mpc current)" ]; then
        if [[ "$(mpc status | sed -n '2p' )" =~ '[playing]' ]]; then
            echo "$line" | sed 's|{\"name|{\"name\":\"mpd\",\"color\": \"'"#eeeeee"'\",\"full_text\":\"[  '"$my_song"]'\"},{\"name|' || exit 1
        else
            echo "$line" | sed 's|{\"name|{\"name\":\"mpd\",\"color\": \"'"#777777"'\",\"full_text\":\"[  '"$my_song"]'\"},{\"name|' || exit 1
        fi
    else
        echo "$line" || exit 1
    fi
done
