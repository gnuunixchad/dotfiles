#!/bin/env bash
# @author nate zhou
# @since 2024
# codeberg.org/unixchad/dotfiles
# github.com/gnuunixchad/dotfiles
# os information

k_result=$(uname -r)
p_result=$(pacman -Q | wc -l)
u_result=$(uptime -p | sed 's/up //' | sed 's/ days/ D/' | sed 's/ hours/ H/' | sed 's/ minutes/ min/')
m_result=$(free -h | awk 'NR==2 {print $3 "/" $2}')
s_result=$(free -h | awk 'NR==3 {print $3 "/" $2}')

print_colors() {
    printf "colors:    "
    for i in {0..15};do
        printf "\e[48;5;${i}m \e[0m"
        if [ $((($i + 1) % 16)) -eq 0 ]; then
            printf "\n"
        fi
    done
}

echo "kernel:    $k_result"
echo "package:   $p_result"
echo "uptime:    $u_result"
echo "memory:    $m_result"
echo "swap:      $s_result"
print_colors
