#!/usr/bin/sh
# @author nate zhou
# @since 2024,2025,2026
# @depends python-mutagen
# add title tags to audio files, using the file name except the extension


prompt="Add title tags using the file name excluding the extension"

usage() {
    cat << _EOF_
USAGE:
        $(basename "$0") [OPTION] FILES...
        Add title tags using the file name excluding the extension.
OPTION:
        -n,--numeric    ignore the numeric prefix in the filename.
        -p,--prefix PREFIX
                        ignore the given prefix in the filename.
EXAMPLES:
        $(basename "$0") -p '[0-9]*_' *.mp3
_EOF_
    exit 0
}

add_title() {
    file="$1"

    filename=$(basename "$file")

    title="${filename%.*}"

    [ -n "$prefix" ] && title="${title#${prefix}}"

    mid3v2 -t "$title" "$file"
}

write_title() {
    echo "$prompt"
    read -p "continue?(y/n)" choice && [ $choice = 'y' ] || exit 0

    for file in "$@"; do
        add_title "$file"
    done

    exit 0
}

[ -z "$1" ] && usage

while [ -n "$1" ]; do
    case "$1" in
        -n|--numeric)
            shift
            prefix='[0-9]*-'
            prompt="${prompt}, ignoring the numeric prefix in the filename"
            write_title "$@"
            ;;
        -p|--prefix)
            shift 1
            prefix=$1
            prompt="${prompt}, ignoring the $prefix prefix in the filename"
            shift
            write_title "$@"
            ;;
        -*)
            usage
            ;;
        *)
            prefix=''
            write_title "$@"
            ;;
    esac
done
