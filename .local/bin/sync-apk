#!/usr/bin/sh
# @author nate zhou
# @since 2026
# @depends android-tools
# sync-apk - backup APK files from the android device via adb

APK_ENV="${HOME}/.local/sbin/sync-apk.env"
apk_dir="${HOME}/pkg/apk"

usage() {
    cat <<_EOF_
USAGE:
        $(basename "$0") [OPTION]
        backup APK files from the android device via adb
OPTIONS:
        -l,--list       list packages from attached device
        -w,--write      write packages to $APK_ENV
        -e,--edit       edit packages in $APK_ENV
        -h,--help       print this help info
_EOF_
    exit 0
}

list_packages() {
    adb shell pm list packages | sed 's/^package://'
    exit 0
}

write_packages() {
    read -p "Continue? (y/n): " choice
    if [ "$choice" = "y" ] || [ "$choice" = "Y" ]; then
        list_packages > "$APK_ENV"
    fi

    exit 0
}

edit_packages() {
    $EDITOR "$APK_ENV"
    exit 0
}

get_path() {
    adb shell pm path $1
}

is_existing() {
    ls "${apk_dir}/${name}" >/dev/null 2>&1
}

clear_old_packages() {
    # keep the 3 most recent backup for each package, remove the older
    ls -t ${apk_dir}/${pkg}-*.apk | tail -n +4 | xargs -r rm --
}

pull_package() {
    adb pull "$path" "${apk_dir}/${name}"
}

sync_packages() {
    read -p "Continue? (y/n): " choice
    if [ "$choice" = "y" ] || [ "$choice" = "Y" ]; then
        local pkgs=$(cat ${HOME}/.local/sbin/sync-apk.env)

        mkdir -p "$apk_dir"

        for pkg in $pkgs; do
            path="$(get_path $pkg  | sed 's/^package://')"
            name="$(echo $path | sed 's|.*==/\(.*\)==/.*|\1|').apk"

            is_existing || pull_package

            clear_old_packages
        done
    fi


    exit 0
}

if [ -z "$1" ]; then
    sync_packages
else
    while [ -n "$1" ]; do
        case "$1" in
            -l|--list)
                list_packages
                ;;
            -w|--write)
                write_packages
                ;;
            -e|--edit)
                edit_packages
                ;;
            *) usage
                ;;
        esac
    done
fi
