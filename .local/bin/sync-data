#!/bin/bash
# sync-data
# @author nate zhou
# @since 2024
# codeberg.org/unixchad/dotfiles
# github.com/gnuunixchad/dotfiles

my_source_path="$HOME/doc $HOME/mus $HOME/pic $HOME/vid $HOME/repo"
my_destination="/data/"

echo "rsync -avh --delete --progress $my_source_path $my_destination"
# Do not quote $my_source_path as rsync would take the paths with space as a single argument, looking for a non-existing directory with that long concatenated path.
# The simplest way is to not quote the path, but make sure there aren't spaces or slash as a part of the file's pathname.
rsync --dry-run -avh --delete --progress $my_source_path $my_destination

read -p "Continue? (y/n): " choice
if [[ $choice == "y" || $choice == "Y" ]]; then
    rsync -avh --delete --progress $my_source_path $my_destination
    # pacman
    rsync -avh --delete --progress /var/cache/pacman/pkg/ $HOME/repo/linux/pacman/
    # yay
    rsync -avh --delete --progress $HOME/.cache/yay/ $HOME/repo/linux/yay/
else
    echo "aborted"
    exit 0
fi
