#!/usr/bin/sh
# @author nate zhou
# @since 2024,2025
# confirm to remove image with wmenu

user_choice="$(printf "no\nyes" | wmenu -f "SourceCodePro medium 13" -p "rm? ($@)" -S 6f3f89 -s ffffff -M 6f3f89 -m ffffff)"

if [ "$user_choice" = "yes" ]; then
    rm "$@"
    notify-send -u low -r 3301 "swayimg"  "image removed"
else
    exit 0
fi
