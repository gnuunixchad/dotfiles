#!/bin/bash
# sync-config
# @author nate zhou
# @since 2024

read -p "Continue? (y/n): " choice
if [[ $choice == "y" || $choice == "Y" ]]; then
    rsync -avh --delete --progress --relative --exclude .config/gtk-2.0/gtkfilechooser.ini ~/.local/bin ~/.bashrc ~/.inputrc ~/.profile ~/.gnupg/gpg.conf ~/.config/calcurse/conf ~/.config/dunst ~/.config/fcitx5/{config,profile} ~/.config/firejail ~/.config/foot ~/.config/{gtk-2.0,gtk-3.0,gtk-4.0} ~/.config/imv ~/.config/mpd/mpd.conf ~/.config/mpv ~/.config/mutt/{account.example,muttrc,mailcap} ~/.config/ncmpcpp/{config,bindings} ~/.config/newsboat/config.example ~/.config/nvim/{init.vim,colors} ~/.config/vim/vimrc ~/.config/qt5ct/qt5ct.conf ~/.config/qt6ct/qt6ct.conf ~/.config/ranger ~/.config/sway ~/.config/swaylock ~/.config/task/taskrc ~/.config/waybar ~/.config/wget ~/.config/zathura ~/.config/{user.js,user.js.nfox} ~/.config/smb.conf ~/.config/code-flags.conf ~/.config/Code\ -\ OSS/User/{keybindings.json,settings.json} ~/.config/ttyper ~/.config/git/config.example ~/.ssh/config.example ~/.config/newsboat/urls.example ~/doc/dotfiles/

    rsync -avh --delete --progress ~/doc/dotfiles/home/nate/ ~/doc/note/usr/swayarch/

    # sync sway dotfiles git repo
    # exclude install_sway.md to not delete it in destination path
    #rsync -avh --delete --progress --exclude .git --exclude install_sway.md ~/doc/dotfiles/home/nate/ ~/doc/git/swayarch/
    
    # codeberg dotfiles repo
    # new files need be manually added to destination before this script can sync
    rsync -avh --existing --progress --exclude .git/ ~/doc/dotfiles/home/nate/ ~/doc/git/dotfiles

    # crontab
    crontab -l > ~/doc/datafiles/crontab

    # data  files
    rsync -avh --delete --progress --relative ~/.local/sbin/.git/ ~/.local/app ~/.local/sbin ~/.local/share/nvim ~/.ssh/config ~/.config/btop/btop.conf ~/.config/calcurse/calendar.ical ~/.config/cls ~/.config/git ~/.config/mpd/playlists ~/.config/newsboat/urls ~/.config/task/task ~/.config/mutt/{account1,account1.gpg} ~/.vscode-oss/extensions ~/doc/datafiles/

    # neovim plugins
    rsync -avh --delete --progress --relative --exclude .git/ ~/.local/share/nvim ~/doc/datafiles/home/nate/.local/share/nvim

    # sync bookmark file
    rsync -avh --delete --progress --exclude .git/ ~/doc/bookmarks ~/doc/datafiles/
    # censor private address from bookmarks and write to bookmarks-on-screen
    grep -n "##############################below-are-private##############################" ~/doc/bookmarks/bookmarks | cut -d: -f1 | xargs -I {} sed -n '1,{}p' ~/doc/bookmarks/bookmarks > ~/doc/bookmarks/bookmarks-on-screen

else
    echo "aborted"
    exit 0
fi
