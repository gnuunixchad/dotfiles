#!/bin/bash
# @author nate zhou
# @since 2024
# codeberg.org/unixchad/dotfiles
# github.com/gnuunixchad/dotfiles
# open ebooks with zathura with wmenu 

search_path=("$HOME/doc/ebooks" 
            #"/more/paths"
            )

    selected_file=$(find "${search_path[@]}" -type f | grep -e .epub$ -e .pdf$  | wmenu -p "wbook" -i -l 10 -f "SourceCodePro bold 13" )

# don't open zathura if none file selected
if [ -n "$selected_file" ]; then
    zathura "$selected_file"
fi
