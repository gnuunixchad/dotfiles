#!/bin/bash
# sync-config
# @author nate zhou
# @since 2024
# codeberg.org/unixchad/dotfiles
# github.com/gnuunixchad/dotfiles

heart="$HOME/doc/heart"
dotfiles="$HOME/doc/unixchad/dotfiles"

read -p "Continue? (y/n): " choice
if [[ $choice == "y" || $choice == "Y" ]]; then

    rsync -R /etc/{default/grub,firejail/firecfg.config,samba/smb.conf,ssh/sshd_config,systemd/logind.conf,tlp.conf,vconsole.conf,libvirt/network.conf,ufw/{user.rules,user6.rules}} /usr/local/share/kbd/keymaps/us-custom.map.gz "$heart"/

else
    echo "aborted"
    exit 0
fi
